# Configuration for Base diffusion training

from __gin__ import dynamic_registration

import musdis
import musdis.pipeline.model
import musdis.pipeline.networks

# Constants
LATENT_DIM = 64
DIFFUSION_STEPS = 1000

### ARCHITECTURE ###

# UNet Decoder Configuration
musdis.pipeline.networks.UNet1D:
    in_channels = %LATENT_DIM
    out_channels = %LATENT_DIM
    channels = [256, 512, 1024]
    cond_channels = 0
    time_cond_channels = %LATENT_DIM
    time_embed_dim = 128
    kernel_size = 3

### MODEL ###

model_class = @musdis.pipeline.model.Diffusion

musdis.pipeline.model.Diffusion:
    net = @musdis.pipeline.networks.UNet1D()
    encoder = None
    encoder_time = None
    latent_dim = %LATENT_DIM
    num_diffusion_steps = %DIFFUSION_STEPS
    beta_start = 1e-4
    beta_end = 0.005
    drop_value = -4.0
    drop_rate = 0.2

musdis.pipeline.model.Diffusion.fit.grad_clip_max_norm = 0.5
musdis.pipeline.model.Diffusion.fit.ema_decay = 0.999